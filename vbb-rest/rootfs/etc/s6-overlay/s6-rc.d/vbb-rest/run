#!/command/with-contenv bashio

bashio::log.info "Starting vbb-rest"

export NODE_ENV=production
export PORT=3000
export REDIS_URL=redis://127.0.0.1:6379

# Hostname is only used for self-referential links and the OpenAPI spec.
if bashio::config.has_value 'hostname'; then
    HOSTNAME="$(bashio::config 'hostname')"
else
    HOSTNAME="localhost"
fi
export HOSTNAME

bashio::log.info "Waiting for valkey to start before starting vbb-rest"
bashio::net.wait_for 6379 localhost 300

cd /app || bashio::exit.nok "Could not change to /app"
exec node index.js
